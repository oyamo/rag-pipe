PORT=8080
PIPE_PORT=8082
INFERENCE_PORT=8081

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=rag_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_DSN=postgres://postgres:postgrespassword@postgres:5432/rag_db?sslmode=disable

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_USE_SSL=false

NATS_URL=nats://nats:4222
NATS_STREAM=RAG_PIPE
NATS_TOPIC=documents.ingested
NATS_SUBJECT=documents.ingested
NATS_CONSUMER=pipe_workers
NATS_DLQ_SUBJECT=documents.dlq
NATS_MAX_DELIVERIES=3

WORKER_CONCURRENCY=10
EMBEDDING_DIMENSION=1536
EMBEDDING_MODEL_VERSION=text-embedding-3-small

OTEL_SERVICE_NAME=rag-pipe-system
OTEL_COLLECTOR_URL=otel-collector:4318

GHCR_OWNER=oyamo
